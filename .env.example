# PostgreSQL
POSTGRES_USER=soundatlas_user
POSTGRES_PASSWORD=soundatlas_password
POSTGRES_DB=soundatlas_db
DATABASE_URL=postgresql+asyncpg://soundatlas_user:soundatlas_password@localhost:5432/soundatlas_db

# Redis
REDIS_URL=redis://localhost:6379

# Spotify API
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# CORS
CORS_ORIGINS=http://localhost:3000

# App
APP_NAME=SoundAtlas API
DEBUG=true
